



REM LOAD A DIRECTORY
REM THE DIRECTORY IS A BASIC PROGRAM
REM WITH A LINK, LINE NUMBER, AND NULL LINE TERMINATOR
REM THE DIRECTORY IS TERMINATED BY 3 NULLS

D=8
GOSUB LINE1000
CLOSE 8
END

LINE1000:
 REM PRINT A DIRECTORY
 OPEN D,8,0,"$"
 REM -- PRG STARTS WITH A 2 BYTE LOAD ADDRESS
 GOSUB DIR_READ_BIN_NUM16

 REM START OF BASIC LINE
 DIR_START_READ:
 GOSUB DIR_READ_BIN_NUM16: REM --- 2 BYTE LINE LINK, IGNORE
 GOSUB DIR_READ_BIN_NUM16: REM --- LINE NUMBER/FILE SIZE
 
 IF ST<>0 THEN RETURN
 GOSUB DIR_READ_STR_2_NULL: PRINT A;: PRINT AA$: REM --- READ A BASIC LINE
 IF ST=0 GOTO DIR_START_READ
 RETURN

DIR_READ_STR_2_NULL: 
 REM --- READ STRING TO NULL. RETURNS AA$
 AA$=""
 
 DIR_LOOP1:
  GET#D,A$
  IF A$="" THEN RETURN
  AA$=AA$+A$
  GOTO DIR_LOOP1
  ## RETURN


 
 REM --- READ AND DISCARD DATA
 FOR I=1 TO BC
  IF ST<>0 THEN DIR_SKIP1
  GET#D,A$
 DIR_SKIP1: 
 NEXT
 RETURN
 
 REM --- READ AND PRINT BINARY DATA
 IF A=0 THEN DIR_PRINT_BLANK
 PRINT A;
DIR_PRINT_BLANK:
 PRINT
 RETURN


DIR_READ_BIN_NUM16:
 REM --- READ A 16 BIT BINARY NUMBER INTO A
 A1=0:A2=0
 GOSUB DIR_READ_BIN_NUM8:A1=A
 GOSUB DIR_READ_BIN_NUM8:A2=A
 A=A2*256+A1
 RETURN
 
DIR_READ_BIN_NUM8: 
 REM --- READ AN 8 BIT BINARY NUMBER INTO A
 A=0  
 IF ST<>0 THEN RETURN
 GET#D,A$
 IF A$<>"" THEN A=ASC(A$)
 RETURN
