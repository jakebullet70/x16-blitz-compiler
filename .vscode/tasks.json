{
    "version": "2.0.0",
    "options": {
        "cwd": "${workspaceFolder}"
    },
    "tasks": [
        {
            "label": "Build (libs + release)",
            "type": "shell",
            "command": "${workspaceFolder}\\build.bat",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "Build + GPC.PRG",
            "type": "shell",
            "command": "${workspaceFolder}\\build.bat",
            "args": [ "gpc" ],
            "problemMatcher": [],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "Build + Run (x16emu)",
            "type": "shell",
            "command": "${workspaceFolder}\\build.bat",
            "args": [ "run" ],
            "problemMatcher": [],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "${workspaceFolder}\\build.bat",
            "args": [ "clean" ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        }
    ]
}
